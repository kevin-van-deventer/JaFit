{
  "name": "fitness-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cloudflare": "npm run build && wrangler dev",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cf:d1:create": "wrangler d1 create progressive-workout-coach-db",
    "cf:d1:migrate:local": "wrangler d1 migrations apply progressive-workout-coach-db --local",
    "cf:d1:migrate:remote": "wrangler d1 migrations apply progressive-workout-coach-db --remote",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.14",
    "wrangler": "^4.95.0"
  }
}
