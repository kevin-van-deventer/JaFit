{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "progressive-workout-coach",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-27",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "progressive-workout-coach-db",
      "database_id": "768bb554-97da-460e-9054-5c75401fb4fa",
      "migrations_dir": "./migrations"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
